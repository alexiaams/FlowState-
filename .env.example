# Bedrock / AWS credentials
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_LITELLM_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0

# Local proxy key used between OpenWebUI and LiteLLM.
# This can be any strong local string.
LITELLM_MASTER_KEY=local-litellm-key-change-me

# Local OpenWebUI secret.
# This can be any strong local string.
WEBUI_SECRET_KEY=local-openwebui-secret-change-me
