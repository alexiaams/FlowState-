# Bedrock / AWS settings
AWS_REGION=us-west-2

# Option A: long-term Bedrock API key. Recommended if this is the single key
# you received from Bedrock.
AWS_BEARER_TOKEN_BEDROCK=replace-me

# Option B: classic AWS IAM credentials. Leave these empty if using Option A.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Model IDs that your AWS account can access.
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_LITELLM_MODEL=bedrock/converse/global.anthropic.claude-sonnet-4-6

# Alternative:
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-6-v1
# BEDROCK_LITELLM_MODEL=bedrock/converse/global.anthropic.claude-opus-4-6-v1

# Local proxy key used between OpenWebUI and LiteLLM.
# This can be any strong local string.
LITELLM_MASTER_KEY=local-litellm-key-change-me

# Local OpenWebUI secret.
# This can be any strong local string.
WEBUI_SECRET_KEY=local-openwebui-secret-change-me
